{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/kits/[kitId]",
      "regex": "^/kits/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPkitId": "nxtPkitId"
      },
      "namedRegex": "^/kits/(?<nxtPkitId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/3d-printing-services",
      "regex": "^/3d\\-printing\\-services(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/3d\\-printing\\-services(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/make-a-kit",
      "regex": "^/make\\-a\\-kit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/make\\-a\\-kit(?:/)?$"
    },
    {
      "page": "/mech-it-easy-kits",
      "regex": "^/mech\\-it\\-easy\\-kits(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/mech\\-it\\-easy\\-kits(?:/)?$"
    },
    {
      "page": "/mech-it-easy-labs",
      "regex": "^/mech\\-it\\-easy\\-labs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/mech\\-it\\-easy\\-labs(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}